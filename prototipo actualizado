  .chart-bar.alt {
    background: linear-gradient(180deg, #57D9A3 0%, #0a8a5c 100%);
  }

  .chart-labels {
    display: flex;
    justify-content: space-around;
    padding: 6px 16px 0;
    font-size: 11px;
    color: var(--gray-400);
  }

