<script>
  let selectedRole = 'Administrador';

  function selectRole(el, role) {
    document.querySelectorAll('.role-tab').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
    selectedRole = role;
  }

  function doLogin() {
    const btn = document.querySelector('.btn-login');
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> &nbsp; Verificando...';
    btn.disabled = true;
    setTimeout(() => {
      document.getElementById('login-screen').style.display = 'none';
      document.getElementById('app').style.display = 'flex';
      showToast('Bienvenido, Álvaro Díaz — ' + selectedRole);
    }, 1200);
  }

  function doLogout() {
    document.getElementById('app').style.display = 'none';
    document.getElementById('login-screen').style.display = 'flex';
    document.querySelector('.btn-login').innerHTML = '<i class="fas fa-sign-in-alt"></i> &nbsp; Ingresar al sistema';
    document.querySelector('.btn-login').disabled = false;
  }

  function showPage(pageId, navEl) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    const target = document.getElementById('page-' + pageId);
    if (target) target.classList.add('active');
    if (navEl) navEl.classList.add('active');
    const titles = {
      'dashboard': 'Dashboard',
      'unidades': 'Gestión de Unidades',
      'conductores': 'Gestión de Conductores',
      'rutas': 'Rutas de Operación',
      'planificacion': 'Planificación',
      'incidentes': 'Registro de Incidentes',
      'analisis': 'Inteligencia y Análisis',
      'reportes': 'Reportes',
      'usuarios': 'Usuarios y Roles',
      'auditoria': 'Auditoría'
    };
    document.getElementById('page-breadcrumb').textContent = titles[pageId] || pageId;
  }

  function showToast(msg) {
    const t = document.getElementById('toast');
    document.getElementById('toast-msg').textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3000);
  }

  function openModal(id) {
    document.getElementById(id).classList.add('open');
  }

  function closeModal(id) {
    document.getElementById(id).classList.remove('open');
  }

  // Cerrar modal al click fuera
  document.querySelectorAll('.modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', function(e) {
      if (e.target === this) this.classList.remove('open');
    });
  });

  // Tab bar clicks (conductores)
  document.querySelectorAll('.tab-item').forEach(tab => {
    tab.addEventListener('click', function() {
      this.closest('.tab-bar').querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
      this.classList.add('active');
    });
  });
</script>
