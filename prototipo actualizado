<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SGROAS — Sistema de Gestión de Recursos Operativos, Administrativos y de Seguridad</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
  :root {
    --blue: #57B9FF;
    --blue-dark: #1A8FE3;
    --blue-deeper: #0A6AB8;
    --blue-light: #C2E4FF;
    --blue-ultra-light: #EEF7FF;
    --white: #FFFFFF;
    --gray-50: #F8FBFF;
    --gray-100: #EFF5FB;
    --gray-200: #D9E8F5;
    --gray-400: #94B4CC;
    --gray-600: #5A7A94;
    --gray-800: #1E3347;
    --sidebar-w: 260px;
    --topbar-h: 64px;
    --radius: 12px;
    --shadow: 0 2px 12px rgba(87,185,255,0.10);
    --shadow-lg: 0 8px 32px rgba(87,185,255,0.15);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--gray-50);
    color: var(--gray-800);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ─── LOGIN ─── */
  #login-screen {
    min-height: 100vh;
    background: linear-gradient(135deg, #0A6AB8 0%, #57B9FF 60%, #C2E4FF 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  #login-screen::before {
    content: '';
    position: absolute;
    width: 600px; height: 600px;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
    top: -200px; right: -150px;
  }

  #login-screen::after {
    content: '';
    position: absolute;
    width: 400px; height: 400px;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
    bottom: -150px; left: -100px;
  }

  .login-card {
    background: rgba(255,255,255,0.97);
    border-radius: 20px;
    padding: 48px 44px;
    width: 440px;
    box-shadow: 0 24px 80px rgba(10,106,184,0.25);
    position: relative;
    z-index: 2;
    animation: slideUp 0.6s ease;
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .login-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }

  .login-logo-icon {
    width: 48px; height: 48px;
    background: linear-gradient(135deg, var(--blue-dark), var(--blue));
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 22px;
  }

  .login-logo-text h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--blue-deeper);
    letter-spacing: -0.5px;
  }

  .login-logo-text span {
    font-size: 11px;
    color: var(--gray-600);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    font-weight: 500;
  }

  .login-subtitle {
    font-size: 13.5px;
    color: var(--gray-600);
    margin-bottom: 32px;
    border-bottom: 1px solid var(--gray-100);
    padding-bottom: 24px;
  }

  .form-group {
    margin-bottom: 18px;
  }

  .form-group label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--gray-800);
    margin-bottom: 7px;
  }

  .form-group .input-wrap {
    position: relative;
  }

  .form-group .input-wrap i {
    position: absolute;
    left: 13px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--gray-400);
    font-size: 15px;
  }

  .form-group input, .form-group select {
    width: 100%;
    padding: 11px 14px 11px 40px;
    border: 1.5px solid var(--gray-200);
    border-radius: 10px;
    font-size: 14px;
    font-family: 'DM Sans', sans-serif;
    color: var(--gray-800);
    background: var(--gray-50);
    transition: all 0.2s;
    outline: none;
  }

  .form-group input:focus {
    border-color: var(--blue);
    background: white;
    box-shadow: 0 0 0 3px rgba(87,185,255,0.15);
  }

  .login-role-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 24px;
  }

  .role-tab {
    flex: 1;
    padding: 8px;
    border: 1.5px solid var(--gray-200);
    border-radius: 8px;
    text-align: center;
    font-size: 12.5px;
    font-weight: 500;
    color: var(--gray-600);
    cursor: pointer;
    transition: all 0.2s;
    background: white;
  }

  .role-tab.active, .role-tab:hover {
    border-color: var(--blue);
    background: var(--blue-ultra-light);
    color: var(--blue-dark);
  }

  .btn-login {
    width: 100%;
    padding: 13px;
    background: linear-gradient(135deg, var(--blue-dark), var(--blue));
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 600;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    transition: all 0.2s;
    margin-top: 8px;
    letter-spacing: 0.2px;
  }

  .btn-login:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(87,185,255,0.4);
  }

  .login-footer {
    text-align: center;
    font-size: 12px;
    color: var(--gray-400);
    margin-top: 20px;
  }

  /* ─── MAIN APP ─── */
  #app {
    display: none;
    min-height: 100vh;
  }

  /* SIDEBAR */
  .sidebar {
    width: var(--sidebar-w);
    background: linear-gradient(180deg, #0A5A9C 0%, #0D6DB5 40%, #1A8FE3 100%);
    position: fixed;
    top: 0; left: 0; bottom: 0;
    display: flex;
    flex-direction: column;
    z-index: 100;
    box-shadow: 4px 0 20px rgba(10,90,156,0.3);
  }

  .sidebar-brand {
    padding: 20px 20px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.12);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .sidebar-brand-icon {
    width: 40px; height: 40px;
    background: rgba(255,255,255,0.2);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 18px;
    flex-shrink: 0;
  }

  .sidebar-brand-text h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: white;
    letter-spacing: -0.3px;
    line-height: 1.2;
  }

  .sidebar-brand-text span {
    font-size: 10px;
    color: rgba(255,255,255,0.6);
    letter-spacing: 0.8px;
    text-transform: uppercase;
  }

  .sidebar-section {
    padding: 12px 12px 4px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
  }

  .sidebar-nav {
    flex: 1;
    overflow-y: auto;
    padding: 8px 12px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.18s;
    margin-bottom: 2px;
    color: rgba(255,255,255,0.75);
    font-size: 14px;
    font-weight: 400;
    position: relative;
  }

  .nav-item i {
    width: 20px;
    text-align: center;
    font-size: 16px;
    flex-shrink: 0;
  }

  .nav-item:hover {
    background: rgba(255,255,255,0.12);
    color: white;
  }

  .nav-item.active {
    background: rgba(255,255,255,0.2);
    color: white;
    font-weight: 500;
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
  }

  .nav-badge {
    margin-left: auto;
    background: #FF5B5B;
    color: white;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 20px;
  }

  .nav-badge.blue {
    background: rgba(255,255,255,0.25);
    color: white;
  }

  .sidebar-footer {
    padding: 16px 12px;
    border-top: 1px solid rgba(255,255,255,0.12);
  }

  .sidebar-user {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 10px;
    background: rgba(255,255,255,0.1);
    cursor: pointer;
  }

  .user-avatar {
    width: 34px; height: 34px;
    border-radius: 8px;
    background: rgba(255,255,255,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
    color: white;
    flex-shrink: 0;
  }

  .user-info h4 {
    font-size: 13px;
    font-weight: 600;
    color: white;
  }

  .user-info span {
    font-size: 11px;
    color: rgba(255,255,255,0.6);
  }

  /* MAIN CONTENT */
  .main-content {
    margin-left: var(--sidebar-w);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* TOPBAR */
  .topbar {
    height: var(--topbar-h);
    background: white;
    border-bottom: 1px solid var(--gray-200);
    display: flex;
    align-items: center;
    padding: 0 28px;
    gap: 16px;
    position: sticky;
    top: 0;
    z-index: 50;
    box-shadow: 0 1px 8px rgba(87,185,255,0.08);
  }

  .topbar-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--gray-800);
    flex: 1;
  }

  .topbar-title span {
    font-size: 13px;
    color: var(--gray-600);
    font-weight: 400;
    font-family: 'DM Sans', sans-serif;
  }

  .topbar-actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .topbar-btn {
    width: 36px; height: 36px;
    border-radius: 9px;
    border: 1.5px solid var(--gray-200);
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--gray-600);
    font-size: 15px;
    transition: all 0.2s;
    position: relative;
  }

  .topbar-btn:hover {
    border-color: var(--blue);
    color: var(--blue-dark);
    background: var(--blue-ultra-light);
  }

  .topbar-btn .notif-dot {
    position: absolute;
    top: 6px; right: 6px;
    width: 7px; height: 7px;
    background: #FF5B5B;
    border-radius: 50%;
    border: 1.5px solid white;
  }

  .topbar-date {
    font-size: 12px;
    color: var(--gray-400);
    padding: 6px 12px;
    background: var(--gray-100);
    border-radius: 8px;
  }

  /* PAGES */
  .page {
    display: none;
    padding: 28px;
    flex: 1;
    animation: fadeIn 0.3s ease;
  }

  .page.active {
    display: block;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* CARDS */
  .card {
    background: white;
    border-radius: var(--radius);
    border: 1px solid var(--gray-200);
    padding: 24px;
    box-shadow: var(--shadow);
  }

  .card-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: var(--gray-800);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .card-title i {
    color: var(--blue);
  }

  /* STAT CARDS */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }

  .stat-card {
    background: white;
    border-radius: var(--radius);
    padding: 20px 22px;
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow);
    position: relative;
    overflow: hidden;
    transition: all 0.2s;
  }

  .stat-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--blue-dark), var(--blue));
  }

  .stat-card.green::before { background: linear-gradient(90deg, #0a8a5c, #1DBBAA); }
  .stat-card.orange::before { background: linear-gradient(90deg, #d4620a, #F5A623); }
  .stat-card.red::before { background: linear-gradient(90deg, #a32222, #E24B4A); }

  .stat-icon {
    width: 40px; height: 40px;
    border-radius: 10px;
    background: var(--blue-ultra-light);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--blue-dark);
    font-size: 18px;
    margin-bottom: 12px;
  }

  .stat-card.green .stat-icon { background: #e1f5ee; color: #0a8a5c; }
  .stat-card.orange .stat-icon { background: #fff3e0; color: #d4620a; }
  .stat-card.red .stat-icon { background: #fff0f0; color: #a32222; }

  .stat-value {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--gray-800);
    line-height: 1;
    margin-bottom: 5px;
  }

  .stat-label {
    font-size: 12.5px;
    color: var(--gray-600);
  }

  .stat-trend {
    font-size: 12px;
    font-weight: 500;
    margin-top: 8px;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .stat-trend.up { color: #0a8a5c; }
  .stat-trend.down { color: #E24B4A; }

  /* TABLES */
  .table-wrap { overflow-x: auto; }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13.5px;
  }

  thead th {
    text-align: left;
    padding: 10px 14px;
    font-size: 11.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--gray-600);
    border-bottom: 1.5px solid var(--gray-200);
    background: var(--gray-50);
  }

  tbody td {
    padding: 12px 14px;
    border-bottom: 1px solid var(--gray-100);
    color: var(--gray-800);
  }

  tbody tr:hover td {
    background: var(--blue-ultra-light);
  }

  tbody tr:last-child td { border-bottom: none; }

  /* BADGES */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 11.5px;
    font-weight: 600;
  }

  .badge.active { background: #e1f5ee; color: #0a6b45; }
  .badge.inactive { background: #fff0f0; color: #a32222; }
  .badge.warning { background: #fff3e0; color: #b35d00; }
  .badge.blue { background: var(--blue-ultra-light); color: var(--blue-deeper); }
  .badge.gray { background: var(--gray-100); color: var(--gray-600); }
  .badge.critical { background: #ff2d2d22; color: #c0000a; }
  .badge.high { background: #ff850022; color: #cc5500; }
  .badge.medium { background: #ffcc0022; color: #9a7800; }
  .badge.low { background: #00c47822; color: #006b42; }

  /* GRID LAYOUTS */
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }
  .col-span-2 { grid-column: span 2; }

  /* FILTERS BAR */
  .filters-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }

  .filter-input {
    padding: 8px 14px;
    border: 1.5px solid var(--gray-200);
    border-radius: 8px;
    font-size: 13.5px;
    font-family: 'DM Sans', sans-serif;
    color: var(--gray-800);
    background: white;
    outline: none;
    transition: all 0.2s;
  }

  .filter-input:focus {
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(87,185,255,0.15);
  }

  .btn {
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 13.5px;
    font-weight: 500;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: none;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--blue-dark), var(--blue));
    color: white;
  }

  .btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(87,185,255,0.35);
  }

  .btn-outline {
    background: white;
    color: var(--blue-dark);
    border: 1.5px solid var(--blue);
  }

  .btn-outline:hover {
    background: var(--blue-ultra-light);
  }

  .btn-ghost {
    background: var(--gray-100);
    color: var(--gray-800);
    border: 1px solid var(--gray-200);
  }

  .btn-ghost:hover {
    background: var(--gray-200);
  }

  .btn-sm { padding: 5px 10px; font-size: 12px; }

  .btn-danger {
    background: #fff0f0;
    color: #a32222;
    border: 1px solid #ffd4d4;
  }

  /* FORM ELEMENTS */
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
  }

  .form-field label {
    display: block;
    font-size: 12.5px;
    font-weight: 500;
    color: var(--gray-600);
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.4px;
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    width: 100%;
    padding: 10px 14px;
    border: 1.5px solid var(--gray-200);
    border-radius: 8px;
    font-size: 13.5px;
    font-family: 'DM Sans', sans-serif;
    color: var(--gray-800);
    background: var(--gray-50);
    outline: none;
    transition: all 0.2s;
  }

  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    border-color: var(--blue);
    background: white;
    box-shadow: 0 0 0 3px rgba(87,185,255,0.15);
  }

  .form-field textarea { resize: vertical; min-height: 90px; }

  /* PAGE HEADER */
  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .page-header h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--gray-800);
    margin-bottom: 4px;
  }

  .page-header p {
    font-size: 13.5px;
    color: var(--gray-600);
  }

  /* TABS */
  .tab-bar {
    display: flex;
    gap: 4px;
    border-bottom: 2px solid var(--gray-200);
    margin-bottom: 24px;
  }

  .tab-item {
    padding: 10px 18px;
    font-size: 13.5px;
    font-weight: 500;
    color: var(--gray-600);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: all 0.2s;
  }

  .tab-item.active {
    color: var(--blue-dark);
    border-bottom-color: var(--blue);
  }

  .tab-item:hover:not(.active) {
    color: var(--gray-800);
    background: var(--gray-100);
    border-radius: 8px 8px 0 0;
  }

  /* PROGRESS BARS */
  .progress-bar {
    height: 6px;
    background: var(--gray-200);
    border-radius: 3px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--blue-dark), var(--blue));
    border-radius: 3px;
    transition: width 0.5s ease;
  }

  .progress-fill.green { background: linear-gradient(90deg, #0a8a5c, #1DBBAA); }
  .progress-fill.orange { background: linear-gradient(90deg, #d4620a, #F5A623); }
  .progress-fill.red { background: linear-gradient(90deg, #a32222, #E24B4A); }

  /* IMAGE UPLOAD */
  .upload-zone {
    border: 2px dashed var(--gray-200);
    border-radius: 12px;
    padding: 32px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    background: var(--gray-50);
  }

  .upload-zone:hover {
    border-color: var(--blue);
    background: var(--blue-ultra-light);
  }

  .upload-zone i {
    font-size: 36px;
    color: var(--gray-400);
    margin-bottom: 10px;
  }

  .upload-zone p { font-size: 13.5px; color: var(--gray-600); }
  .upload-zone small { font-size: 11.5px; color: var(--gray-400); }

  /* AI BADGE */
  .ai-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    background: linear-gradient(135deg, #6a35d4, #9B59B6);
    color: white;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.3px;
  }

  /* INCIDENTS */
  .incident-card {
    background: white;
    border-radius: 10px;
    border: 1px solid var(--gray-200);
    padding: 16px 20px;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 16px;
    transition: all 0.2s;
