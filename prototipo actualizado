    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(87,185,255,0.1);
  }

  .route-line {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 10px;
    font-size: 12.5px;
    color: var(--gray-600);
  }

  .route-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--blue);
    flex-shrink: 0;
  }

  .route-dot.end {
    background: var(--blue-deeper);
  }

  .route-dash {
    flex: 1;
    height: 1.5px;
    background: repeating-linear-gradient(90deg, var(--blue-light) 0, var(--blue-light) 4px, transparent 4px, transparent 8px);
  }

  /* CHART PLACEHOLDER */
  .chart-area {
    width: 100%;
    height: 180px;
    background: var(--gray-50);
    border-radius: 10px;
    border: 1px solid var(--gray-100);
    display: flex;
    align-items: flex-end;
    justify-content: space-around;
    padding: 16px 16px 0;
    gap: 6px;
    position: relative;
    overflow: hidden;
  }

  .chart-bar {
    flex: 1;
    border-radius: 4px 4px 0 0;
    background: linear-gradient(180deg, var(--blue) 0%, var(--blue-dark) 100%);
    opacity: 0.85;
    transition: opacity 0.2s;
    position: relative;
